# =========================================
# TSP local environment (example)
# Copy this file to .env and replace secrets.
# =========================================

# Common
TZ=Asia/Shanghai

# MySQL
MYSQL_PORT=3306
MYSQL_DATABASE=test_db
MYSQL_USER=test_user
MYSQL_PASSWORD=CHANGE_ME_MYSQL_USER_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD
PHPMYADMIN_PORT=8080

# Redis
REDIS_PORT=6379
REDIS_COMMANDER_PORT=8081

# Samba AD / LDAP
SAMBA_REALM=EXAMPLE.COM
SAMBA_DOMAIN=EXAMPLE
SAMBA_ADMIN_PASSWORD=CHANGE_ME_SAMBA_ADMIN_PASSWORD
SAMBA_TEST_USER_PASSWORD=CHANGE_ME_SAMBA_TEST_USER_PASSWORD
SAMBA_DNS_FORWARDER=8.8.8.8
SAMBA_ALLOW_INSECURE_LDAP=true
SAMBA_SERVER_ROLE=dc

LDAP_PORT=389
LDAPS_PORT=636
GC_PORT=3268
DNS_PORT=53
KERBEROS_PORT=88

# LDAP Account Manager
LAM_PORT=8082
LAM_PASSWORD=CHANGE_ME_LAM_PASSWORD
LDAP_DOMAIN=example.com
LDAP_BASE_DN=DC=example,DC=com
LDAP_USERS_DN=CN=Users,DC=example,DC=com
LDAP_GROUPS_DN=CN=Users,DC=example,DC=com
LDAP_USER_DN=CN=Administrator,CN=Users,DC=example,DC=com
