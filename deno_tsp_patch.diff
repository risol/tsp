 use crate::file_system::VfsRoot;
+use deno_path_util::url_to_file_path;
+
+/// Check if a file extension requires transpilation (TypeScript, TSX, or TSP)
+fn needs_transpilation(media_type: MediaType, specifier: &Url) -> bool {
+  match media_type {
+    MediaType::TypeScript | MediaType::Tsx => true,
+    MediaType::Unknown => {
+      // TSP file support: check for .tsp extension
+      if let Ok(path) = url_to_file_path(specifier) {
+        if let Some(ext) = path.extension() {
+          return ext.eq_ignore_ascii_case("tsp");
+        }
+      }
+      false
+    }
+    _ => false,
+  }
+}
+
+/// Get the media type for transpilation (maps .tsp to Tsx)
+fn get_transpile_media_type(media_type: MediaType, specifier: &Url) -> MediaType {
+  if media_type == MediaType::Unknown {
+    if let Ok(path) = url_to_file_path(specifier) {
+      if let Some(ext) = path.extension() {
+        if ext.eq_ignore_ascii_case("tsp") {
+          return MediaType::Tsx;
+        }
+      }
+    }
+  }
+  media_type
+}
+
+/// Transpile TypeScript/TSX/TSP source code to JavaScript
+fn transpile_source(
+  source: &str,
+  specifier: &Url,
+  media_type: MediaType,
+) -> Result<String, AnyError> {
+  let parsed_source = deno_ast::parse_program(deno_ast::ParseParams {
+    specifier: specifier.clone(),
+    text: source.into(),
+    media_type,
+    capture_tokens: false,
+    scope_analysis: false,
+    maybe_syntax: None,
+  })?;
+
+  let transpile_result = parsed_source.transpile(
+    &TranspileOptions {
+      imports_not_used_as_values: deno_ast::ImportsNotUsedAsValues::Remove,
+      ..Default::default()
+    },
+    &TranspileModuleOptions::default(),
+    &EmitOptions {
+      source_map: SourceMapOption::None,
+      ..Default::default()
+    },
+  )?;
+
+  let emit = transpile_result.into_source();
+  Ok(emit.text)
+}
 
