{
  "scopeName": "text.html.eta",
  "patterns": [
    {
      "include": "text.html.basic#tag-stuff"
    },
    {
      "match": "(<%)(=*|-*)(.*?)(-*)(%>)",
      "captures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "keyword.control.eta.html" },
        "3": { "name": "source.js.embedded.html" },
        "4": { "name": "keyword.control.eta.html" },
        "5": { "name": "punctuation.definition.tag.end.html" }
      },
      "name": "meta.embedded.block.eta"
    },
    {
      "match": "(<%=)(.*?)(%>)",
      "captures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "source.js.embedded.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "name": "meta.embedded.line.eta"
    }
  ]
}
