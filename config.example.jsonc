{
  // 文档根目录 - TSX 文件所在的目录
  "root": "./www",

  // 监听端口 - HTTP 服务器监听的端口号
  "port": 9000,

  // 开发模式 - 开启后会显示详细的错误堆栈信息
  // true: 开发模式，显示详细错误
  // false: 生产模式，隐藏敏感信息
  "dev": false,

  // 访问日志文件路径（可选）
  // 如果不设置，日志将输出到控制台
  // 如果设置为文件路径，日志将写入该文件（例如: "./access.log"）
  // "accessLogPath": "./access.log"
}
