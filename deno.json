{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read --allow-write --allow-env --allow-run src/main.ts --dev",
    "start": "deno run --allow-net --allow-read --allow-write --allow-env src/main.ts",
    "compile": "deno compile --allow-net --allow-read --allow-write --allow-sys --allow-env --output tspserver src/main.ts",
    "build": "deno run --allow-all src/build_tool.ts",

    "precompile": "deno run --allow-net --allow-read --allow-write --allow-env src/precompile_tool.ts",
    "precompile:clean": "deno run --allow-net --allow-read --allow-write --allow-env --allow-run src/precompile_tool.ts clean",

    "test": "deno run --allow-all tests/run_all_tests.ts",
    "test:unit": "deno run --allow-all tests/run_unit_tests.ts",
    "test:e2e": "deno run --allow-all tests/run_e2e_tests.ts",
    "test:hot-reload": "deno run --allow-all tests/hot_reload_source_test.ts",
    "test:injection": "deno test --allow-all tests/unit/injection_test.ts",

    "check": "deno check src/main.ts src/cache.ts src/context.ts src/router.ts src/injection-typed.ts src/precompiler_lib.ts src/static.ts",
    "check:all": "deno check src/ www/",
    "fmt": "deno fmt --allow-write src/ www/ tests/",
    "fmt:check": "deno fmt --check src/ www/ tests/",
    "lint": "deno lint src/ www/ tests/",
    "clean": "rm -rf tspserver tspserver.exe tests/tspserver-test tests/tspserver-test.exe config.json config.jsonc .cache dist"
  },
  "imports": {
    "@deno/loader": "jsr:@deno/loader@^0.3.11",
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1.0.0",
    "std/path": "jsr:@std/path@1.0.0",
    "preact": "npm:preact@10.25.4",
    "preact-render-to-string": "npm:preact-render-to-string@6.6.3",
    "nanoid": "npm:nanoid@5.0.9",
    "mysql2": "npm:mysql2@^2.3.3",
    "redis": "npm:redis@^4.6.0",
    "ldapts": "npm:ldapts@^5.0.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["deno.window", "DOM"],
    "types": ["./types.d.ts"]
  }
}
