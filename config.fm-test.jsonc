{
  // 文件管理器测试配置
  "root": "./www",
  "port": 9001,
  "dev": true,

  // 文件管理器配置
  "fileManager": {
    "enabled": true,
    "path": "/__filemanager",
    "password": "test123",
    "allowOutsideRoot": false,
    "deniedPaths": [".git", ".deno", "node_modules", ".cache"],
    "maxUploadSize": 104857600,
    "allowDelete": true,
    "allowRename": true,
    "allowMkdir": true,
    "allowMove": false
  }
}
